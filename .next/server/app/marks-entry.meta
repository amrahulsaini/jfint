{
  "headers": {
    "x-nextjs-stale-time": "300",
    "x-nextjs-prerender": "1",
    "x-next-cache-tags": "_N_T_/layout,_N_T_/marks-entry/layout,_N_T_/marks-entry/page,_N_T_/marks-entry"
  },
  "segmentPaths": [
    "/_tree",
    "/_full",
    "/marks-entry/__PAGE__",
    "/marks-entry",
    "/_index",
    "/_head"
  ]
}